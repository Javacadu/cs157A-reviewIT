{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/.opencode/**": "allow"
    },
    "bash": {
      "*": "allow",
      "git commit*": "deny",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "rm -rf*": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    }
  }
}